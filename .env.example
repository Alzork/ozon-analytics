# cp .env.example .env

# Ozon Seller API
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key

# Ozon Performance API (ads)
OZON_PERF_CLIENT_ID=your_ozon_perf_client_id
OZON_PERF_CLIENT_SECRET=your_ozon_perf_client_secret

# Google Sheets
GOOGLE_CREDS=path/to/google-creds.json
GOOGLE_SHEET_NAME=Your Daily Sheet
GOOGLE_SHEET_NAME_OP=Your Operational Sheet
GOOGLE_SHEET_NAME_OBOR=Your Supply Sheet
GOOGLE_SHEET_NAME_DAY=Your SKU Sheet
GOOGLE_SHEET_ID=your_google_sheet_id
SHEET_ID=your_google_sheet_id
GSHEET_ID=your_google_sheet_id
GOOGLE_SHEET_ID_MANUAL=your_google_sheet_id
GOOGLE_SHEET_WORKSHEET_MANUAL=Profit Calculator

# VK Teams bot
VKTEAMS_BOT_TOKEN=your_vkteams_bot_token
VKTEAMS_API=https://myteam.mail.ru/bot/v1
VK_CHAT_ID=your_vk_chat_id
VK_TEAMS_CHAT_ID=your_vk_chat_id
VKTEAMS_CHAT_ID=your_vk_chat_id

# PostgreSQL (Grafana backend)
PG_HOST=localhost
PG_PORT=5432
PG_DB=your_database_name
PG_USER=your_database_user
PG_PASSWORD=your_database_password
